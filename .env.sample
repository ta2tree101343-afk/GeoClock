# Expo public environment variables
# EXPO_PUBLIC_ variables are embedded in the application bundle.
# Do not store passwords, secret keys, or private credentials here.

EXPO_PUBLIC_USER_POOL_ID=
EXPO_PUBLIC_CLIENT_ID=
EXPO_PUBLIC_API_BASE_URL=

# App Store Connect API
ASCAPI_KEY_ID=
ASCAPI_ISSUER_ID=
ASCAPI_KEY_CONTENT=

# Apple Developer account
APPLE_ID=

# Match certificate repository
MATCH_GIT_URL=
MATCH_PASSWORD=