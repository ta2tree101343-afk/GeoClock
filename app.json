{
  "expo": {
    "name": "GeoClock",
    "slug": "geoclock",
    "scheme": "geoclock",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.geoclock.app"
    },
    "android": {
      "package": "com.geoclock.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-maps",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "現在地と勤務地の位置関係を表示するために使用します"
        }
      ]
    ]
  }
}
